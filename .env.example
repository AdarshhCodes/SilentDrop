# SilentDrop — Backend Environment Variables
# Copy this file to .env and fill in the values.

# ─── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/silentdrop

# ─── Session (Passport OAuth flow) ────────────────────────────────────────────
SESSION_SECRET=replace-with-a-long-random-string

# ─── JWT secrets ───────────────────────────────────────────────────────────────
# Access token secret — signs short-lived (15 min) access JWTs.
JWT_SECRET=replace-with-a-long-random-access-secret

# Refresh token secret — signs long-lived (7 day) refresh JWTs.
# MUST be different from JWT_SECRET so compromise of one does not
# compromise the other.
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-secret

# ─── GitHub OAuth App ──────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# ─── URLs ──────────────────────────────────────────────────────────────────────
BACKEND_URL=https://silentdrop-backend.onrender.com
FRONTEND_URL=https://silent-drop.vercel.app

# ─── Rate limiting (optional override) ────────────────────────────────────────
# Overrides the default 15-minute window for both the general API limiter
# and the strict GitHub login limiter.  Useful in test environments to run
# rate-limit tests without waiting 15 real minutes.
# Example: RATE_LIMIT_WINDOW_MS=100
# RATE_LIMIT_WINDOW_MS=

# ─── GitHub token (optional) ───────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your-optional-github-pat-for-higher-api-limits
